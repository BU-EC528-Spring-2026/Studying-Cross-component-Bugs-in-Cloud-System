{
  "name": "spark4_on_yarn_dual_jdk",
  "required": [
    {
      "scope": "effective_conf",
      "key": "spark.yarn.appMasterEnv.JAVA_HOME",
      "equals": "/opt/openjdk-17",
      "severity": "warning",
      "title": "Spark 4 Application Master JDK is not explicitly set"
    },
    {
      "scope": "effective_conf",
      "key": "spark.executorEnv.JAVA_HOME",
      "equals": "/opt/openjdk-17",
      "severity": "warning",
      "title": "Spark 4 executor JDK is not explicitly set"
    }
  ],
  "equal_keys": [
    {
      "keys": [
        "spark.yarn.appMasterEnv.JAVA_HOME",
        "spark.executorEnv.JAVA_HOME"
      ],
      "severity": "warning",
      "title": "AM and executor JAVA_HOME values are inconsistent"
    }
  ]
}
